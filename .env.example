# --- Web (@daifend/web) ---
NEXT_PUBLIC_DAIFEND_MODE=demo
# demo | live  (demo = legacy Socket mock; live = telemetry-service / gateway)
NEXT_PUBLIC_API_GATEWAY_URL=http://127.0.0.1:8080
NEXT_PUBLIC_TELEMETRY_URL=http://127.0.0.1:4001

# --- Shared backend ---
DAIFEND_ENV=development
POSTGRES_URL=postgresql+asyncpg://daifend:daifend@localhost:5432/daifend
REDIS_URL=redis://localhost:6379/0
NATS_URL=nats://localhost:4222
QDRANT_URL=http://localhost:6333
CLICKHOUSE_HTTP_URL=http://localhost:8123
CLICKHOUSE_ENABLED=true
KAFKA_BOOTSTRAP_SERVERS=localhost:19092
KAFKA_TELEMETRY_TOPIC=daifend.telemetry.raw
DEFAULT_TENANT_ID=default
S3_ENDPOINT=http://localhost:9000
JWT_SECRET=change-me-in-production-use-openssl-rand-hex-32
INTERNAL_SERVICE_TOKEN=dev-internal-token

# OIDC (optional — gateway validates RS256 from JWKS, then falls back to HS256)
# OIDC_JWKS_URL=https://your-tenant.auth0.com/.well-known/jwks.json
# OIDC_ISSUER=https://your-tenant.auth0.com/
# OIDC_AUDIENCE=https://api.daifend.example

# OpenTelemetry OTLP HTTP (e.g. Jaeger local: http://localhost:4318)
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

# Phase 3 — engine hardening (local dev often leaves these unset = gates off)
# ENGINE_REQUIRE_INTERNAL_TOKEN=true
# INTERNAL_SERVICE_TOKEN=dev-internal-token
# GATEWAY_SEND_INTERNAL_TOKEN=true
# MEMORY_GRPC_TARGET=127.0.0.1:50051
# MEMORY_GRPC_TLS=false
# MTLS_CA_BUNDLE=/path/to/ca.pem
# MTLS_CLIENT_CERT=/path/to/client.pem
# MTLS_CLIENT_KEY=/path/to/client-key.pem
# OPA_URL=http://127.0.0.1:8181

# Prisma (apps/web) — mirrors Alembic Postgres
# DATABASE_URL=postgresql://daifend:daifend@localhost:5432/daifend
